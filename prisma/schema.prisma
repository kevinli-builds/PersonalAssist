generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Supabase transaction pooler (port 6543, pgbouncer=true)
  directUrl = env("DIRECT_URL") // Supabase direct/session connection (port 5432) — used by db push
  // This Supabase project is shared with another app (Furnisher) whose tables
  // live in `public`. PersonalAssist is isolated in its own `personalassist`
  // schema so the two never collide. Prisma only manages the schemas listed here.
  schemas   = ["personalassist"]
}

// One remembered fact/event, extracted by Claude from a freeform message.
model Entry {
  id         String     @id @default(cuid())
  type       String // event | health | birthday | task | note
  title      String
  date       DateTime? // primary date of the thing itself (past or future)
  recurrence String? // "yearly" → reminders auto-reschedule; anything else is informational
  tags       String     @default("") // comma-separated lowercase tags
  note       String     @default("")
  raw        String // the original message as typed
  createdAt  DateTime   @default(now())
  reminders  Reminder[]

  @@schema("personalassist")
}

model Reminder {
  id        String   @id @default(cuid())
  entryId   String
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  remindAt  DateTime
  label     String
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@schema("personalassist")
}

// Web Push subscription per browser/device.
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@schema("personalassist")
}

// Failed login attempts — powers per-IP rate limiting / lockout on
// POST /api/auth/login. In-memory counters don't survive Vercel serverless
// (each request may hit a fresh instance), so the throttle state lives in the DB.
// Rows older than the window are swept opportunistically; a successful login
// clears the offending IP's rows.
model LoginAttempt {
  id        String   @id @default(cuid())
  ip        String
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
  @@schema("personalassist")
}

// Bearer sessions — only the sha256 hash of the token is stored.
model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@schema("personalassist")
}
