# Supabase Postgres (free tier). Dashboard → Connect → ORMs → Prisma shows both URLs.
# DATABASE_URL = transaction pooler (port 6543) — app runtime
# DIRECT_URL   = session/direct connection (port 5432) — schema pushes
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Anthropic API key — powers message parsing and Q&A
ANTHROPIC_API_KEY=sk-ant-...

# Model for extraction/Q&A. Default: claude-opus-4-8.
# Set to claude-haiku-4-5 to cut cost (~5x cheaper, usually fine for short messages).
# CLAUDE_MODEL=claude-opus-4-8

# The password you type to log in (single-user app)
APP_PASSWORD=pick-a-strong-password

# Shared secret protecting /api/cron/notify.
# On Vercel, setting CRON_SECRET makes Vercel Cron send it automatically.
CRON_SECRET=pick-another-strong-secret

# Web Push VAPID keys — generate once with: npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:you@example.com

# Same value as WEB_PUSH_PUBLIC_KEY (exposed to the browser for subscribing)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
